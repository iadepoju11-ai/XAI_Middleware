# Copy to .env and fill in values before running

# Database — SQLite for dev, PostgreSQL for prod
DATABASE_URL=sqlite:///audit.db
# DATABASE_URL=postgresql://admin:admin123@localhost:5432/legacy_bank

# Kafka — set true only when docker-compose kafka service is running
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Model artefacts
MODEL_PATH=models/credit_model.pkl
SCALER_PATH=models/scaler.pkl
MODEL_VERSION=1.0.0

# Flask
FLASK_ENV=development
FLASK_PORT=5000
SECRET_KEY=dev-secret-change-in-prod

# Legacy DB (PostgreSQL source for seed_db.py)
LEGACY_DB_HOST=localhost
LEGACY_DB_PORT=5432
LEGACY_DB_NAME=legacy_bank
LEGACY_DB_USER=admin
LEGACY_DB_PASSWORD=admin123
